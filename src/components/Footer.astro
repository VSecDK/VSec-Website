---
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-6">

    <div class="flex flex-col items-center md:items-start gap-1">
      <a href="/" class="font-mono font-semibold text-text-primary text-sm">
        <span class="text-accent">[</span>VSec<span class="text-accent">]</span>
      </a>
      <p class="font-mono text-xs text-text-muted">Non-profit Danish infosec community</p>
    </div>

    <div class="flex items-center gap-5">
      <a href="https://discord.com/invite/XCUja4Q" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-200" aria-label="Discord">
        <Icon name="discord" size={18} />
      </a>
      <a href="https://twitter.com/VSecDK" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-200" aria-label="Twitter/X">
        <Icon name="twitter" size={16} />
      </a>
      <a href="https://github.com/VSecDK" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-200" aria-label="GitHub">
        <Icon name="github" size={18} />
      </a>
      <a href="https://www.youtube.com/@VSecDK" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-200" aria-label="YouTube">
        <Icon name="youtube" size={18} />
      </a>
    </div>

    <div class="flex flex-col items-center md:items-end gap-1.5">
      <p class="font-mono text-xs text-text-muted">© {year} VSec</p>
      <div class="flex items-center gap-3">
        <a href="/rss/posts.xml" class="font-mono text-[10px] text-text-muted hover:text-accent transition-colors duration-200 flex items-center gap-1" title="Posts RSS feed">
          <Icon name="rss" size={11} class="text-orange-400" />
          Posts
        </a>
        <span class="text-border text-xs">·</span>
        <a href="/rss/incidents.xml" class="font-mono text-[10px] text-text-muted hover:text-accent transition-colors duration-200 flex items-center gap-1" title="Incidents RSS feed">
          <Icon name="rss" size={11} class="text-orange-400" />
          Incidents
        </a>
        <span class="text-border text-xs">·</span>
        <a href="/rss/events.xml" class="font-mono text-[10px] text-text-muted hover:text-accent transition-colors duration-200 flex items-center gap-1" title="Events RSS feed">
          <Icon name="rss" size={11} class="text-orange-400" />
          Events
        </a>
      </div>
    </div>

  </div>
</footer>
