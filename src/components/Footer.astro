        <span class="text-accent">[</span>VSec<span class="text-accent">]</span>
      </a>
      <p class="font-mono text-xs text-text-muted">Non-profit Danish infosec community</p>
    </div>

    <div class="flex items-center gap-5">
      <a href="https://discord.com/invite/XCUja4Q" target="_blank" rel="noopener" class="text-text-muted hover:text-accent transition-colors duration-200" aria-label="Discord">
