---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={icon.fill ?? 'none'}
  stroke={icon.stroke}
  stroke-width={icon.strokeWidth}
  stroke-linecap={icon.strokeLinecap}
  stroke-linejoin={icon.strokeLinejoin}
  class={cls}
  aria-hidden={role ? undefined : 'true'}
  role={role}
  aria-label={ariaLabel}
  set:html={icon.html}
/>
