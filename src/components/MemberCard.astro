---

interface Props {
  name: string;
  handle: string;
  bio?: string;
  avatar?: string;
  discordAvatar?: string;
  github?: string;
  twitter?: string;
  linkedin?: string;
  website?: string;
  ctftime?: string;
  roles: string[];
  verified: boolean;
  featured: boolean;
}

const {
  name, handle, bio, avatar, discordAvatar,
  github, twitter, linkedin, website, ctftime,
  roles, verified, featured,
} = Astro.props;

// Avatar priority: discord (bot-filled) → manual → github (local) → initials
const avatarUrl = discordAvatar
  ?? avatar
  ?? (github ? `/images/avatars/${github}.png` : null);

const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();

const socials = [
  github    && { href: `https://github.com/${github}`,        label: 'GitHub',   icon: 'github' },
  twitter   && { href: `https://twitter.com/${twitter}`,      label: 'Twitter',  icon: 'twitter' },
  linkedin  && { href: `https://linkedin.com/in/${linkedin}`,  label: 'LinkedIn', icon: 'linkedin' },
  website   && { href: website.startsWith('http') ? website : `https://${website}`, label: 'Website', icon: 'website' },
  ctftime   && { href: ctftime.startsWith('http') ? ctftime : `https://ctftime.org/user/${ctftime}`, label: 'CTFtime', icon: 'ctftime' },
].filter(Boolean) as { href: string; label: string; icon: string }[];
---

<div class:list={['card flex gap-4', featured && 'border-accent/15']}>
  <!-- Avatar -->
  <div class="flex-shrink-0">
    {avatarUrl ? (
      <>
        <img
          src={avatarUrl}
          alt={name}
          width="48"
          height="48"
          loading="lazy"
          decoding="async"
          class="w-12 h-12 rounded-full object-cover border border-border"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="w-12 h-12 rounded-full border border-border bg-bg-elevated items-center justify-center font-mono font-bold text-sm text-accent" style="display:none">
          {initials}
        </div>
      </>
    ) : (
      <div class="w-12 h-12 rounded-full border border-border bg-bg-elevated flex items-center justify-center font-mono font-bold text-sm text-accent">
        {initials}
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="flex-1 min-w-0">
    <div class="mb-1">
      <div class="flex items-center gap-1.5 flex-wrap">
        <span class="font-mono font-semibold text-sm text-text-primary">{name}</span>
        {verified && (
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-accent flex-shrink-0" role="img" aria-label="Verified member">
            <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
      </div>
      <span class="font-mono text-xs text-text-muted">@{handle}</span>
    </div>

    <!-- Roles -->
    {roles.filter(r => r.toLowerCase() !== 'verified').length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-2">
        {roles.filter(r => r.toLowerCase() !== 'verified').map(role => <span class="tag text-[10px] py-0">{role}</span>)}
      </div>
    )}

    {bio && (
      <p class="font-sans text-xs text-text-secondary leading-relaxed mb-3 line-clamp-2">{bio}</p>
    )}

    <!-- Social links -->
    {socials.length > 0 && (
      <div class="flex items-center gap-3">
        {socials.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${name} on ${s.label}`}
            class="text-text-muted hover:text-accent transition-colors duration-200"
          >
            {s.icon === 'github' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
            )}
            {s.icon === 'twitter' && (
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {s.icon === 'linkedin' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {s.icon === 'website' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
              </svg>
            )}
            {s.icon === 'ctftime' && (
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</div>
