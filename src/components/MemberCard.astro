---
import Icon from './Icon.astro';

interface Props {
  name: string;
  handle: string;
  bio?: string;
  avatar?: string;
  discordAvatar?: string;
  github?: string;
  twitter?: string;
  linkedin?: string;
  website?: string;
  ctftime?: string;
  roles: string[];
  verified: boolean;
  featured: boolean;
}

const {
  name, handle, bio, avatar, discordAvatar,
  github, twitter, linkedin, website, ctftime,
  roles, verified, featured,
} = Astro.props;

// Avatar priority: discord (bot-filled) → manual → github (local) → initials
const avatarUrl = discordAvatar
  ?? avatar
  ?? (github ? `/images/avatars/${github}.png` : null);

const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();

const socials = [
  github    && { href: `https://github.com/${github}`,        label: 'GitHub',   icon: 'github' },
  twitter   && { href: `https://twitter.com/${twitter}`,      label: 'Twitter',  icon: 'twitter' },
  linkedin  && { href: `https://linkedin.com/in/${linkedin}`,  label: 'LinkedIn', icon: 'linkedin' },
  website   && { href: website.startsWith('http') ? website : `https://${website}`, label: 'Website', icon: 'website' },
  ctftime   && { href: ctftime.startsWith('http') ? ctftime : `https://ctftime.org/user/${ctftime}`, label: 'CTFtime', icon: 'ctftime' },
].filter(Boolean) as { href: string; label: string; icon: string }[];
---

<div class:list={['card flex gap-4', featured && 'border-accent/15']}>
  <!-- Avatar -->
  <div class="flex-shrink-0">
    {avatarUrl ? (
      <>
        <img
          src={avatarUrl}
          alt={name}
          width="48"
          height="48"
          loading="lazy"
          decoding="async"
          class="w-12 h-12 rounded-full object-cover border border-border"
          data-avatar
        />
        <div class="hidden w-12 h-12 rounded-full border border-border bg-bg-elevated items-center justify-center font-mono font-bold text-sm text-accent">
          {initials}
        </div>
      </>
    ) : (
      <div class="w-12 h-12 rounded-full border border-border bg-bg-elevated flex items-center justify-center font-mono font-bold text-sm text-accent">
        {initials}
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="flex-1 min-w-0">
    <div class="mb-1">
      <div class="flex items-center gap-1.5 flex-wrap">
        <span class="font-mono font-semibold text-sm text-text-primary">{name}</span>
        {verified && (
          <Icon name="verified" size={14} class="text-accent flex-shrink-0" role="img" aria-label="Verified member" />
        )}
      </div>
      <span class="font-mono text-xs text-text-muted">@{handle}</span>
    </div>

    <!-- Roles -->
    {roles.filter(r => r.toLowerCase() !== 'verified').length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-2">
        {roles.filter(r => r.toLowerCase() !== 'verified').map(role => <span class="tag text-[10px] py-0">{role}</span>)}
      </div>
    )}

    {bio && (
      <p class="font-sans text-xs text-text-secondary leading-relaxed mb-3 line-clamp-2">{bio}</p>
    )}

    <!-- Social links -->
    {socials.length > 0 && (
      <div class="flex items-center gap-3">
        {socials.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${name} on ${s.label}`}
            class="text-text-muted hover:text-accent transition-colors duration-200"
          >
            {s.icon === 'github'   && <Icon name="github"   size={14} />}
            {s.icon === 'twitter'  && <Icon name="twitter"  size={13} />}
            {s.icon === 'linkedin' && <Icon name="linkedin" size={14} />}
            {s.icon === 'website'  && <Icon name="website"  size={14} />}
            {s.icon === 'ctftime'  && <Icon name="ctftime"  size={13} />}
          </a>
        ))}
      </div>
    )}
  </div>
</div>
