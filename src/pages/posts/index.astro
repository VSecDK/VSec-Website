---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SearchFilter from '../../components/SearchFilter.astro';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const members = await getCollection('members');
const memberRolesByName = new Map<string, string[]>();
members.forEach(m => {
  memberRolesByName.set(m.data.name.toLowerCase(), m.data.roles.map(r => r.toLowerCase()));
});
---

<Layout title="Posts" description="Articles and spotlights from the VSec community">

  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex items-start justify-between gap-8 mb-12">
      <div>
        <p class="section-label">// Knowledge shared</p>
        <h1 class="font-mono font-bold text-4xl text-text-primary mb-2">Posts</h1>
        <p class="font-sans text-text-secondary">Articles, guides, and spotlights from the community.</p>
      </div>
      <div class="flex-shrink-0 text-right">
        <p class="font-mono font-bold text-3xl text-accent">{posts.length}</p>
        <p class="font-mono text-xs text-text-muted mb-3">posts</p>
        <a href="https://github.com/VSecDK" target="_blank" rel="noopener noreferrer" class="btn-ghost text-sm">
          Suggest a post
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>
      </div>
    </div>

    <SearchFilter listId="posts-list" placeholder="Search posts…" />

    <div class="grid md:grid-cols-2 gap-5" id="posts-list">
      {posts.map(post => {
        const authorRoles = memberRolesByName.get(post.data.author.toLowerCase()) ?? [];
        const searchText = `${post.data.title} ${post.data.description} ${post.data.author} ${post.data.tags.join(' ')} ${authorRoles.join(' ')}`.toLowerCase();
        const searchTags = [...post.data.tags.map(t => t.toLowerCase()), ...authorRoles].join(',');
        return (
          <a
            href={`/posts/${post.slug}`}
            class="card group flex flex-col gap-4"
            data-search-text={searchText}
            data-search-tags={searchTags}
          >
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <h2 class="font-mono font-semibold text-lg text-text-primary group-hover:text-accent transition-colors duration-200 leading-snug">
              {post.data.title}
            </h2>
            <p class="font-sans text-sm text-text-secondary leading-relaxed flex-1">
              {post.data.description}
            </p>
            <div class="flex items-center justify-between pt-2 border-t border-border">
              <div class="flex items-center gap-3">
                <span class="font-mono text-xs text-text-muted">{post.data.author}</span>
                <span class="text-border">·</span>
                <span class="font-mono text-xs text-text-muted">
                  {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                </span>
              </div>
              {post.data.readingTime && (
                <span class="font-mono text-xs text-accent/60">{post.data.readingTime}</span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </div>

</Layout>
