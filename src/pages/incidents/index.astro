---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import SearchFilter from '../../components/SearchFilter.astro';

const monthNames = [
  '', 'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

type TypeConfig = { label: string; style: string };
const typeConfig: Record<string, TypeConfig> = {
  ransomware:      { label: 'Ransomware',   style: 'text-red-400/80 border-red-400/20 bg-red-400/5' },
  dataleak:        { label: 'Data Leak',    style: 'text-orange-400/80 border-orange-400/20 bg-orange-400/5' },
  hacking:         { label: 'Hacking',      style: 'text-yellow-400/80 border-yellow-400/20 bg-yellow-400/5' },
  'supply-chain':  { label: 'Supply chain', style: 'text-purple-400/80 border-purple-400/20 bg-purple-400/5' },
  unknown:         { label: 'Unknown',      style: 'text-text-muted border-border bg-white/4' },
};

function getTypeConfig(t: string): TypeConfig {
  return typeConfig[t.toLowerCase()] ?? {
    label: t.charAt(0).toUpperCase() + t.slice(1),
    style: 'text-accent/80 border-accent/20 bg-accent/5',
  };
}

const cases = (await getCollection('incidents'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const grouped = cases.reduce<Record<number, Record<number, CollectionEntry<'incidents'>[]>>>((acc, entry) => {
  const year  = entry.data.date.getFullYear();
  const month = entry.data.date.getMonth() + 1;
  if (!acc[year]) acc[year] = {};
  if (!acc[year][month]) acc[year][month] = [];
  acc[year][month].push(entry);
  return acc;
}, {});

const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);

---

<Layout title="Incidents" description="Overview of Danish cybersecurity incidents from VSec CTI League">

  <div class="max-w-5xl mx-auto px-6 py-16">

    <!-- Page header -->
    <div class="flex items-start justify-between gap-8 mb-12">
      <div>
        <p class="section-label">// CTI League</p>
        <h1 class="font-mono font-bold text-4xl text-text-primary mb-2">Incidents</h1>
        <p class="font-sans text-text-secondary max-w-lg leading-relaxed">
          Curated Danish cybersecurity incidents, sorted by year and month.
        </p>
      </div>
      <div class="flex-shrink-0 text-right">
        <p class="font-mono font-bold text-3xl text-accent">{cases.length}</p>
        <p class="font-mono text-xs text-text-muted mb-3">incidents</p>
        <a href="https://github.com/VSecDK" target="_blank" rel="noopener noreferrer" class="btn-ghost text-sm">
          Suggest an incident
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>
      </div>
    </div>

    {cases.length > 0 && (
      <SearchFilter listId="incidents-list" placeholder="Search company, sector, actor…" />
    )}

    {cases.length === 0 ? (
      <div class="p-8 rounded-lg border border-dashed border-border text-center">
        <p class="font-mono text-sm text-text-muted mb-4">No incidents found.</p>
        <a href="https://github.com/VSecDK/VSec-CTI-League/tree/main/cases"
           target="_blank" rel="noopener noreferrer" class="btn-ghost text-sm">
          View directly on GitHub →
        </a>
      </div>
    ) : (
      <div class="space-y-16" id="incidents-list">
        {years.map(year => {
          const months = Object.keys(grouped[year]).map(Number).sort((a, b) => b - a);
          return (
            <section data-search-section>
              <!-- Year heading -->
              <div class="flex items-center gap-4 mb-8">
                <h2 class="font-mono font-bold text-5xl text-accent/15 leading-none select-none">{year}</h2>
                <div class="flex-1 h-px bg-border"></div>
                <span class="font-mono text-xs text-text-muted">
                  {Object.values(grouped[year]).flat().length} incident{Object.values(grouped[year]).flat().length !== 1 ? 's' : ''}
                </span>
              </div>

              <div class="space-y-8">
                {months.map(month => (
                  <div data-search-section>
                    <!-- Month label -->
                    <p class="font-mono text-xs text-text-muted tracking-widest uppercase mb-3 flex items-center gap-3">
                      <span class="inline-block w-1 h-1 rounded-full bg-accent/40"></span>
                      {monthNames[month]}
                    </p>

                    <div class="flex flex-col gap-2">
                      {grouped[year][month].map(entry => {
                        const tc = getTypeConfig(entry.data.type);
                        const searchText = [
                          entry.data.company,
                          entry.data.sector ?? '',
                          entry.data.actor ?? '',
                          entry.data.type,
                          String(year),
                        ].join(' ').toLowerCase();
                        const searchTags = [
                          entry.data.type.toLowerCase(),
                          ...(entry.data.sector ? [entry.data.sector.toLowerCase()] : []),
                        ].join(',');
                        return (
                          <a
                            href={`/incidents/${entry.slug}`}
                            class="card group flex items-start gap-4 hover:border-accent/20 transition-colors duration-200"
                            data-search-text={searchText}
                            data-search-tags={searchTags}
                          >
                            <!-- Date -->
                            <div class="flex-shrink-0 font-mono text-xs text-text-muted w-8 pt-0.5 text-right">
                              {String(entry.data.date.getDate()).padStart(2, '0')}.
                            </div>

                            <div class="flex-1 min-w-0">
                              <div class="flex flex-wrap items-center gap-2 mb-1">
                                <span class:list={['tag text-[10px] py-0 flex-shrink-0', tc.style]}>
                                  {tc.label}
                                </span>
                                <h3 class="font-mono font-semibold text-sm text-text-primary group-hover:text-accent transition-colors duration-200 truncate">
                                  {entry.data.company}
                                </h3>
                              </div>
                              <div class="flex flex-wrap gap-x-4 gap-y-0.5">
                                {entry.data.sector && (
                                  <span class="font-sans text-xs text-text-muted">{entry.data.sector}</span>
                                )}
                                {entry.data.actor && entry.data.actor.toLowerCase() !== 'unknown' && (
                                  <span class="font-sans text-xs text-text-muted">
                                    Actor: {entry.data.actor}
                                  </span>
                                )}
                              </div>
                            </div>

                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" class="text-text-muted group-hover:text-accent flex-shrink-0 mt-1 transition-colors duration-200">
                              <path d="M9 18l6-6-6-6"/>
                            </svg>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    )}

  </div>

</Layout>
