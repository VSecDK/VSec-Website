---
import Layout from '../layouts/Layout.astro';
import MemberCard from '../components/MemberCard.astro';
import { getCollection } from 'astro:content';

const members = (await getCollection('members'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name, 'da'));


// Group by first letter of first name
const grouped = members.reduce<Record<string, typeof members>>((acc, m) => {
  const letter = m.data.name.charAt(0).toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(m);
  return acc;
}, {});

const letters = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'da'));
---

<Layout title="Members" description="Verified VSec community members">

  <div class="max-w-6xl mx-auto px-6 py-16">

    <!-- Header -->
    <div class="flex items-start justify-between gap-8 mb-12">
      <div>
        <p class="section-label">// Community</p>
        <h1 class="font-mono font-bold text-4xl text-text-primary mb-2">Members</h1>
        <p class="font-sans text-text-secondary max-w-lg leading-relaxed">
          Verified members of the VSec community.
          Verification is done via our Discord bot, which links your Discord profile to your VSec identity.
        </p>
      </div>
      <div class="flex-shrink-0 text-right">
        <p class="font-mono font-bold text-3xl text-accent">{members.length}</p>
        <p class="font-mono text-xs text-text-muted">members</p>
      </div>
    </div>

    <!-- Bot under development warning -->
    <div class="mb-6 p-4 rounded-lg border border-yellow-500/30 bg-yellow-500/5 flex items-start gap-3">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-yellow-400 flex-shrink-0 mt-0.5" aria-hidden="true">
        <path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="font-mono text-xs text-yellow-400 leading-relaxed">
        The Discord verification bot is currently under development. Member profiles and avatars may be incomplete.
      </p>
    </div>

    <!-- Verification info -->
    <div class="mb-10 p-5 rounded-lg border border-dashed border-accent/20 bg-accent/3 flex items-start gap-4">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="text-accent flex-shrink-0 mt-0.5">
        <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <div>
        <p class="font-mono text-sm text-text-primary mb-1">How to get verified</p>
        <p class="font-sans text-xs text-text-secondary leading-relaxed">
          Use the <code class="font-mono text-accent/80 bg-accent/5 px-1 rounded">/verify</code> command in our Discord server.
          The bot will automatically link your Discord profile to your VSec page and fill in your avatar and username.
        </p>
      </div>
    </div>

    <!-- Letter navigation -->
    <div class="flex flex-wrap gap-1.5 mb-12">
      {letters.map(letter => (
        <a
          href={`#letter-${letter}`}
          class="font-mono text-xs w-7 h-7 flex items-center justify-center rounded border border-border text-text-muted hover:border-accent/40 hover:text-accent transition-all duration-200"
        >
          {letter}
        </a>
      ))}
    </div>

    <!-- Sections per letter -->
    <div class="space-y-14">
      {letters.map(letter => (
        <section id={`letter-${letter}`}>
          <div class="flex items-center gap-4 mb-5">
            <span class="font-mono font-bold text-4xl text-accent/20 leading-none select-none">{letter}</span>
            <div class="flex-1 h-px bg-border"></div>
            <span class="font-mono text-xs text-text-muted">{grouped[letter].length}</span>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {grouped[letter].map(m => (
              <MemberCard
                name={m.data.name}
                handle={m.data.handle}
                bio={m.data.bio}
                avatar={m.data.avatar}
                discordAvatar={m.data.discordAvatar}
                github={m.data.github}
                twitter={m.data.twitter}
                linkedin={m.data.linkedin}
                website={m.data.website}
                ctftime={m.data.ctftime}
                roles={m.data.roles}
                verified={m.data.verified}
                featured={m.data.featured}
              />
            ))}
          </div>
        </section>
      ))}
    </div>

  </div>

</Layout>
