---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found" description="The page you are looking for does not exist.">
  <div class="max-w-2xl mx-auto px-6 py-32 text-center">
    <p class="section-label mb-4">// 404</p>
    <h1 class="font-mono font-bold text-5xl text-text-primary mb-4 tracking-tight">
      Page not found
    </h1>
    <p class="font-sans text-text-secondary leading-relaxed mb-10">
      The page you are looking for does not exist or has been moved.
    </p>
    <div class="flex items-center justify-center gap-4 flex-wrap">
      <a href="/" class="btn-primary text-sm">Go to home</a>
      <a href="/posts" class="btn-ghost text-sm">See posts</a>
    </div>
  </div>
</Layout>
